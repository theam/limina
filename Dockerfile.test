FROM node:20-slim

WORKDIR /app

# Copy project
COPY package.json package-lock.json ./
RUN npm install
COPY . .

# Create a fresh directory for the user simulation
RUN mkdir /research

WORKDIR /research

# Run limina doctor to see the full prerequisite detection + install flow
# Default: run limina (triggers init flow in empty /research dir)
CMD ["npx", "tsx", "/app/cli/index.ts"]
